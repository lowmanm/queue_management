{
  "id": null,
  "uid": "nexus-queue-ops",
  "title": "Nexus Queue — Operations Dashboard",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "label": "Datasource",
        "current": {}
      },
      {
        "name": "interval",
        "type": "interval",
        "label": "Interval",
        "options": [
          { "selected": false, "text": "30s", "value": "30s" },
          { "selected": true, "text": "1m", "value": "1m" },
          { "selected": false, "text": "5m", "value": "5m" },
          { "selected": false, "text": "10m", "value": "10m" }
        ],
        "current": { "selected": true, "text": "1m", "value": "1m" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Queue Depth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "nexus-prometheus" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "custom": { "stacking": { "mode": "normal" } } }
      },
      "targets": [
        {
          "expr": "nexus_queue_depth",
          "legendFormat": "{{queue}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Task Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "nexus-prometheus" },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "rate(nexus_tasks_total[5m])",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Agent State Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "nexus-prometheus" },
      "options": {
        "legend": { "displayMode": "list", "placement": "right" }
      },
      "targets": [
        {
          "expr": "nexus_agents_active",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "SLA Compliance %",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "nexus-prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 98 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "100 - (rate(nexus_sla_breaches_total[1h]) / rate(nexus_tasks_total[1h])) * 100",
          "legendFormat": "SLA %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "DLQ Depth",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "nexus-prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "nexus_dlq_depth",
          "legendFormat": "DLQ Depth",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Task Handle Time",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "nexus-prometheus" },
      "options": {
        "calculate": false,
        "color": { "scheme": "Oranges", "mode": "scheme" }
      },
      "targets": [
        {
          "expr": "nexus_task_handle_time_seconds_bucket",
          "legendFormat": "{{le}}",
          "refId": "A",
          "format": "heatmap"
        }
      ]
    }
  ]
}
